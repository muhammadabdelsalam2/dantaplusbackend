    {
      "name": "External Orders",
      "item": [
        {
          "name": "Get Materials By Company",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "description": "Returns inventory materials for the selected supplier company. Each material item contains exactly: id, name, category, price. Use id as materials[x][material_product_id], category as materials[x][category], and price as read-only materials[x][price].",
            "url": {
              "raw": "{{base_url}}/api/company/materials/by-company?company_id={{company_id}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "company",
                "materials",
                "by-company"
              ],
              "query": [
                {
                  "key": "company_id",
                  "value": "{{company_id}}"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create External Order - Existing Clinic",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "clinic_id",
                  "value": "{{existing_clinic_id}}",
                  "type": "text",
                  "description": "Existing clinic ID. Backend auto-fills clinic name/phone from the clinic record."
                },
                {
                  "key": "materials[0][material_product_id]",
                  "value": "1",
                  "type": "text",
                  "description": "Selected inventory product id."
                },
                {
                  "key": "materials[0][category]",
                  "value": "Impression Material",
                  "type": "text"
                },
                {
                  "key": "materials[0][quantity]",
                  "value": "5",
                  "type": "text"
                },
                {
                  "key": "materials[0][unit]",
                  "value": "box",
                  "type": "text"
                },
                {
                  "key": "materials[0][price]",
                  "value": "85.50",
                  "type": "text",
                  "description": "Read-only value from inventory. Backend verifies and uses the product price from the database."
                },
                {
                  "key": "materials[1][material_product_id]",
                  "value": "2",
                  "type": "text",
                  "description": "Selected inventory product id."
                },
                {
                  "key": "materials[1][category]",
                  "value": "Endodontics",
                  "type": "text"
                },
                {
                  "key": "materials[1][quantity]",
                  "value": "2",
                  "type": "text"
                },
                {
                  "key": "materials[1][unit]",
                  "value": "pack",
                  "type": "text"
                },
                {
                  "key": "materials[1][price]",
                  "value": "112.00",
                  "type": "text",
                  "description": "Read-only value from inventory. Backend verifies and uses the product price from the database."
                },
                {
                  "key": "shipping_cost",
                  "value": "50.00",
                  "type": "text"
                },
                {
                  "key": "expected_delivery",
                  "value": "2026-07-28",
                  "type": "text"
                },
                {
                  "key": "payment_method",
                  "value": "Cash",
                  "type": "text"
                },
                {
                  "key": "delivery_address",
                  "value": "123 Main St, Metropolis",
                  "type": "text"
                },
                {
                  "key": "notes",
                  "value": "Please call the clinic before delivery.",
                  "type": "text"
                }
              ]
            },
            "description": "Creates an external order for an existing clinic. Form-data array format is materials[0][material_product_id], materials[0][category], materials[0][quantity], materials[0][unit], materials[0][price]. The backend maps material_product_id to product_id, price to unit_price for validation only, expected_delivery to delivery_at, then verifies and uses the actual product price/category from inventory.",
            "url": {
              "raw": "{{base_url}}/api/company/external-orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "company",
                "external-orders"
              ]
            }
          },
          "response": []
        },
