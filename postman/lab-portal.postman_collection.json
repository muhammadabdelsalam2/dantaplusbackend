{
  "info": {
    "name": "Lab Portal Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "token", "value": "" },
    { "key": "order_id", "value": "1" },
    { "key": "delivery_rep_id", "value": "1" },
    { "key": "clinic_id", "value": "1" },
    { "key": "support_ticket_id", "value": "1" },
    { "key": "equipment_id", "value": "1" },
    { "key": "lab_order_token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Orders - List with Stats and Filters",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/lab/orders?clinic=All Clinics&status=All Statuses&priority=All Priorities&search=&per_page=15"
      }
    },
    {
      "name": "Orders - Show",
      "request": { "method": "GET", "url": "{{base_url}}/lab/orders/{{order_id}}" }
    },
    {
      "name": "Orders - Update Status",
      "request": {
        "method": "PATCH",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "status", "value": "Accepted", "type": "text" },
            { "key": "technician_id", "value": "", "type": "text" },
            { "key": "notes", "value": "", "type": "text" },
            { "key": "generate_invoice", "value": "false", "type": "text" },
            { "key": "assign_for_delivery", "value": "false", "type": "text" },
            { "key": "delivery_rep_user_id", "value": "", "type": "text" }
          ]
        },
        "url": "{{base_url}}/lab/orders/{{order_id}}/status"
      }
    },
    {
      "name": "Orders - Assign Technician",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "technician_id", "value": "", "type": "text" },
            { "key": "notes", "value": "", "type": "text" }
          ]
        },
        "url": "{{base_url}}/lab/orders/{{order_id}}/assign-technician"
      }
    },
    {
      "name": "Orders - Complete",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "generate_invoice", "value": "false", "type": "text" },
            { "key": "assign_for_delivery", "value": "false", "type": "text" },
            { "key": "delivery_rep_user_id", "value": "", "type": "text" },
            { "key": "notes", "value": "", "type": "text" }
          ]
        },
        "url": "{{base_url}}/lab/orders/{{order_id}}/complete"
      }
    },
    {
      "name": "Orders - Activity Log",
      "request": { "method": "GET", "url": "{{base_url}}/lab/orders/{{order_id}}/activity-log?range=all" }
    },
    {
      "name": "Orders - Notes",
      "request": { "method": "GET", "url": "{{base_url}}/lab/orders/{{order_id}}/notes" }
    },
    {
      "name": "Orders - Add Note",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "message", "value": "", "type": "text" },
            { "key": "is_internal", "value": "false", "type": "text" }
          ]
        },
        "url": "{{base_url}}/lab/orders/{{order_id}}/notes"
      }
    },
    {
      "name": "Orders - Lab Order JSON",
      "request": { "method": "GET", "url": "{{base_url}}/lab/orders/{{order_id}}/lab-order" }
    },
    {
      "name": "Orders - Public Lab Order Download",
      "auth": { "type": "noauth" },
      "request": { "method": "GET", "url": "{{base_url}}/lab/orders/lab-order/{{lab_order_token}}/download" }
    },
    {
      "name": "Technicians - List",
      "request": { "method": "GET", "url": "{{base_url}}/lab/technicians?search=" }
    },
    {
      "name": "Delivery Reps - List",
      "request": { "method": "GET", "url": "{{base_url}}/lab/delivery-reps?search=&status=Active&per_page=15" }
    },
    {
      "name": "Delivery Reps - Login As Mandoub",
      "request": { "method": "POST", "url": "{{base_url}}/lab/delivery-reps/{{delivery_rep_id}}/login-as" }
    },
    {
      "name": "Partnered Clinics - List",
      "request": { "method": "GET", "url": "{{base_url}}/lab/partnered-clinics?type=All Types&status=All Statuses&search=&per_page=15" }
    },
    {
      "name": "Support Tickets",
      "item": [
        {
          "name": "List My Tickets",
          "request": { "method": "GET", "url": "{{base_url}}/lab/support/tickets?search=&status=&priority=&per_page=10" }
        },
        {
          "name": "Create Ticket",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "", "type": "text" },
                { "key": "category", "value": "Technical", "type": "text" },
                { "key": "priority", "value": "High", "type": "text" },
                { "key": "description", "value": "", "type": "text" },
                { "key": "attachment", "type": "file", "src": "" }
              ]
            },
            "url": "{{base_url}}/lab/support/tickets"
          }
        },
        {
          "name": "Show Ticket With Messages",
          "request": { "method": "GET", "url": "{{base_url}}/lab/support/tickets/{{support_ticket_id}}" }
        },
        {
          "name": "Send Ticket Message",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "message", "value": "", "type": "text" }
              ]
            },
            "url": "{{base_url}}/lab/support/tickets/{{support_ticket_id}}/messages"
          }
        }
      ]
    },
    {
      "name": "Equipment",
      "item": [
        {
          "name": "List Equipment",
          "request": { "method": "GET", "url": "{{base_url}}/lab/equipment?search=&maintenance_status=all&per_page=15" }
        },
        {
          "name": "Show Equipment",
          "request": { "method": "GET", "url": "{{base_url}}/lab/equipment/{{equipment_id}}" }
        },
        {
          "name": "Record Maintenance",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "notes", "value": "", "type": "text" },
                { "key": "maintenance_date", "value": "", "type": "text" },
                { "key": "next_due_date", "value": "", "type": "text" }
              ]
            },
            "url": "{{base_url}}/lab/equipment/{{equipment_id}}/record-maintenance"
          }
        }
      ]
    },
    {
      "name": "Communication - Contacts",
      "request": { "method": "GET", "url": "{{base_url}}/communication/contacts?per_page=20" }
    },
    {
      "name": "Communication - Messages",
      "request": { "method": "GET", "url": "{{base_url}}/communication/conversations/1/messages" }
    },
    {
      "name": "Communication - Send Message",
      "request": {
        "method": "POST",
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "text", "value": "", "type": "text" },
            { "key": "type", "value": "text", "type": "text" }
          ]
        },
        "url": "{{base_url}}/communication/conversations/1/messages"
      }
    }
  ]
}
