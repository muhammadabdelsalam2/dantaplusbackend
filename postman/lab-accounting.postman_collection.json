{
  "info": {
    "name": "Lab Accounting",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000/api"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "invoice_id",
      "value": "1"
    },
    {
      "key": "service_id",
      "value": "1"
    },
    {
      "key": "user_id",
      "value": "1"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Accounting",
      "item": [
        {
          "name": "Invoice Payment Summary",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/accounting/invoices/{{invoice_id}}/payment-summary"
          },
          "response": []
        },
        {
          "name": "Technician Earnings Reports With Materials",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/accounting/technician-earnings?period=all_time&technician_id=all&material_type=all_materials"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Filter Clinics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/filters/clinics"
          },
          "response": []
        },
        {
          "name": "Filter Doctors",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/filters/doctors?clinic_id=all"
          },
          "response": []
        },
        {
          "name": "Filter Case Types",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/filters/case-types"
          },
          "response": []
        },
        {
          "name": "Stats Cards",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/stats?from=&to=&clinic_id=all&doctor_id=all&case_type_id=all"
          },
          "response": []
        },
        {
          "name": "Case Type Breakdown",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/case-type-breakdown?from=&to=&clinic_id=all&doctor_id=all&case_type_id=all"
          },
          "response": []
        },
        {
          "name": "Monthly Completed Cases",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/monthly-completed-cases?from=&to=&clinic_id=all&doctor_id=all&case_type_id=all"
          },
          "response": []
        },
        {
          "name": "Performance Overview",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/performance-overview?from=&to=&clinic_id=all&doctor_id=all&case_type_id=all&sort_by=total_cases&sort_direction=desc"
          },
          "response": []
        },
        {
          "name": "Detailed Case List",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/lab/analytics/detailed-cases?from=&to=&clinic_id=all&doctor_id=all&case_type_id=all&sort_by=due_date&sort_direction=asc"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Settings",
      "item": [
        {
          "name": "Lab Profile",
          "item": [
            {
              "name": "Get Lab Profile",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/profile"
              },
              "response": []
            },
            {
              "name": "Save Lab Profile",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/profile",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "lab_name",
                      "value": "Precision Dental Labs",
                      "type": "text"
                    },
                    {
                      "key": "contact_person",
                      "value": "Mike Ross",
                      "type": "text"
                    },
                    {
                      "key": "email",
                      "value": "contact@precisionlabs.com",
                      "type": "text"
                    },
                    {
                      "key": "phone",
                      "value": "555-0201",
                      "type": "text"
                    },
                    {
                      "key": "address",
                      "value": "789 Tech Park, Metropolis",
                      "type": "text"
                    },
                    {
                      "key": "working_hours",
                      "value": "9am - 6pm, Mon-Fri",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "Services & Pricing",
          "item": [
            {
              "name": "List Services",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/services"
              },
              "response": []
            },
            {
              "name": "Add Service",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/services",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "service_name",
                      "value": "Zirconia Crown",
                      "type": "text"
                    },
                    {
                      "key": "price",
                      "value": "120",
                      "type": "text"
                    },
                    {
                      "key": "turnaround_time_days",
                      "value": "4",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Edit Service",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/services/{{service_id}}",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "service_name",
                      "value": "Zirconia Crown",
                      "type": "text"
                    },
                    {
                      "key": "price",
                      "value": "120",
                      "type": "text"
                    },
                    {
                      "key": "turnaround_time_days",
                      "value": "4",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Delete Service",
              "request": {
                "method": "DELETE",
                "url": "{{base_url}}/lab/settings/services/{{service_id}}"
              },
              "response": []
            }
          ]
        },
        {
          "name": "Users & Roles",
          "item": [
            {
              "name": "List Users",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/users"
              },
              "response": []
            },
            {
              "name": "Add User",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/users",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "full_name",
                      "value": "Lab Reception",
                      "type": "text"
                    },
                    {
                      "key": "email",
                      "value": "lab.reception@example.com",
                      "type": "text"
                    },
                    {
                      "key": "password",
                      "value": "password123",
                      "type": "text"
                    },
                    {
                      "key": "role",
                      "value": "lab_receptionist",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Edit User",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/users/{{user_id}}",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "full_name",
                      "value": "Lab Admin (Precision)",
                      "type": "text"
                    },
                    {
                      "key": "email",
                      "value": "lab.precision@example.com",
                      "type": "text"
                    },
                    {
                      "key": "role",
                      "value": "lab_admin",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "Notifications",
          "item": [
            {
              "name": "Get Notifications",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/notifications"
              },
              "response": []
            },
            {
              "name": "Save Notifications",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/notifications",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "new_case_alerts[in_app_notification]",
                      "value": "true",
                      "type": "text"
                    },
                    {
                      "key": "new_case_alerts[email_notification]",
                      "value": "false",
                      "type": "text"
                    },
                    {
                      "key": "case_update_alerts[in_app_notification]",
                      "value": "true",
                      "type": "text"
                    },
                    {
                      "key": "case_update_alerts[email_notification]",
                      "value": "true",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            }
          ]
        },
        {
          "name": "Communication",
          "item": [
            {
              "name": "Get WhatsApp Settings",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/whatsapp"
              },
              "response": []
            },
            {
              "name": "Save WhatsApp Settings",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/whatsapp",
                "body": {
                  "mode": "formdata",
                  "formdata": [
                    {
                      "key": "provider",
                      "value": "meta_cloud_api",
                      "type": "text"
                    },
                    {
                      "key": "business_phone_number_id",
                      "value": "",
                      "type": "text"
                    },
                    {
                      "key": "whatsapp_business_account_id",
                      "value": "",
                      "type": "text"
                    },
                    {
                      "key": "access_token",
                      "value": "",
                      "type": "text"
                    },
                    {
                      "key": "verify_token",
                      "value": "",
                      "type": "text"
                    }
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Test Connection",
              "request": {
                "method": "POST",
                "url": "{{base_url}}/lab/settings/whatsapp/test",
                "body": {
                  "mode": "formdata",
                  "formdata": []
                }
              },
              "response": []
            },
            {
              "name": "API Logs",
              "request": {
                "method": "GET",
                "url": "{{base_url}}/lab/settings/whatsapp/logs"
              },
              "response": []
            }
          ]
        }
      ]
    }
  ]
}
